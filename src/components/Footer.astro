---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { COMPANY_INFO } from '../consts';
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png'; 

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const texts = lang === 'en' ?
{
  aboutTitle: "About Us",
  aboutText: "We are Jacksonville's trusted plumbing experts, dedicated to providing honest, high-quality service for both residential and commercial needs.",
  linksTitle: "Quick Links",
  contactTitle: "Contact Info",
  rights: "All rights reserved.",
  privacy: "Privacy Policy",
  services: "Services",
  contact: "Contact"
} : {
  aboutTitle: "Sobre Nosotros",
  aboutText: "Somos los expertos en plomería de confianza en Jacksonville, dedicados a brindar un servicio honesto y de alta calidad para necesidades residenciales y comerciales.",
  linksTitle: "Enlaces Rápidos",
  contactTitle: "Contacto",
  rights: "Todos los derechos reservados.",
  privacy: "Política de Privacidad",
  services: "Servicios",
  contact: "Contacto"
};

const homeLink = `/${lang}`;
const servicesLink = `/${lang}/#services`;
const contactLink = `/${lang}/#contact`;
---

<footer class="bg-gray-950 text-white border-t border-white/10 pt-20 pb-10 font-sans">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
<div>
        <a href={homeLink} class="block mb-6 w-40 transition-transform hover:scale-105">
           <Image 
            src={logoImage} 
            alt="Olveras Plumbing" 
            class="w-full h-auto object-contain drop-shadow-[0_4px_15px_rgba(0,0,0,0.6)]" 
          />
        </a>
        <p class="text-gray-400 leading-relaxed text-sm mb-2">
          {texts.aboutText}
        </p>
        
        {/* Sección de Redes y Plataformas con mayor jerarquía */}
        <div class="mt-8 pt-6 border-t border-white/10">
          <span class="block text-xs font-bold uppercase tracking-wider text-gray-500 mb-4">
            {lang === 'en' ? 'Connect with us' : 'Conecta con nosotros'}
          </span>
          
          <div class="flex items-center gap-3">
            {/* Facebook - Ya con su azul característico */}
            <a href="https://www.facebook.com/olverasplumbing" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-[#1877F2]/10 border border-[#1877F2]/30 hover:bg-[#1877F2] flex items-center justify-center text-[#1877F2] hover:text-white transition-all shadow-lg group" aria-label="Facebook">
              <svg fill="currentColor" viewBox="0 0 24 24" class="h-5 w-5 group-hover:scale-110 transition-transform" aria-hidden="true"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
            </a>
            
            {/* Google - Compañía perfecta para el SEO local */}
            <a href={COMPANY_INFO.addressLink} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 hover:bg-white flex items-center justify-center text-gray-400 hover:text-gray-900 transition-all shadow-lg group" title={lang === 'en' ? 'Find us on Google Maps' : 'Encuéntranos en Google Maps'}>
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 group-hover:scale-110 transition-transform"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-6 text-white flex items-center gap-2">
          <span class="w-8 h-1 bg-[#E31B23] rounded-full"></span>
          {texts.linksTitle}
        </h3>
        <ul class="space-y-3">
          <li>
            <a href={homeLink} class="text-gray-400 hover:text-white hover:translate-x-1 transition-all flex items-center gap-2">
              <svg class="w-4 h-4 text-[#E31B23]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              {lang === 'en' ? 'Home' : 'Inicio'}
            </a>
          </li>
          <li>
            <a href={servicesLink} class="text-gray-400 hover:text-white hover:translate-x-1 transition-all flex items-center gap-2">
              <svg class="w-4 h-4 text-[#E31B23]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              {texts.services}
            </a>
          </li>
          <li>
            <a href={contactLink} class="text-gray-400 hover:text-white hover:translate-x-1 transition-all flex items-center gap-2">
              <svg class="w-4 h-4 text-[#E31B23]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              {texts.contact}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold mb-6 text-white flex items-center gap-2">
          <span class="w-8 h-1 bg-[#E31B23] rounded-full"></span>
          {texts.contactTitle}
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#E31B23] shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <a href={COMPANY_INFO.addressLink} target="_blank" class="text-gray-400 hover:text-white transition-colors text-sm leading-tight">
              {COMPANY_INFO.address}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#E31B23] shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href={`tel:${t('phone.primary.link')}`} class="text-gray-400 hover:text-white transition-colors text-sm font-bold">
              {t('phone.primary.display')}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#E31B23] shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <a href={`mailto:${COMPANY_INFO.email}`} class="text-gray-400 hover:text-white transition-colors text-sm break-all">
              {COMPANY_INFO.email}
            </a>
          </li>
        </ul>
      </div>
      
      <div class="relative group h-64 w-full rounded-2xl overflow-hidden border border-white/10 shadow-lg">
          <a href={COMPANY_INFO.addressLink} target="_blank" class="absolute inset-0 z-20" aria-label="Open Map"></a>
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d110058.46352932986!2d-81.76652435000001!3d30.3321838!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88e5b716f1ceafeb%3A0xc4cd7d3896fcc7e2!2sJacksonville%2C%20FL!5e0!3m2!1sen!2sus!4v1707850000000!5m2!1sen!2sus" 
            width="100%" 
            height="100%" 
            style="border:0;"
            allowfullscreen="" 
            loading="lazy" 
            class="w-full h-full grayscale group-hover:grayscale-0 transition-all duration-700 opacity-60 group-hover:opacity-100 scale-110 group-hover:scale-100"
          ></iframe>
          <div class="absolute bottom-3 left-3 z-10 bg-white/90 backdrop-blur text-black text-xs font-bold px-3 py-1 rounded-full shadow-sm pointer-events-none">
            📍 Locate Us
          </div>
      </div>

    </div>

    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-400">
      <p>
        © {new Date().getFullYear()} Olveras Plumbing. {texts.rights}
      </p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors">{texts.privacy}</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>